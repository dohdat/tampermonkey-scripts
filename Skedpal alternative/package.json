{
  "name": "personal-skedpal-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky install .husky",
    "build:css": "npx tailwindcss -i styles/tailwind.input.css -o styles/tailwind.css --content pages/index.html,pages/partials/app-shell.html,pages/partials/modals.html,src/ui/**/*.js --minify",
    "lint": "eslint .",
    "test": "mocha \"test/**/*.test.js\" --exit",
    "test:coverage": "npm run lint && c8 --check-coverage --lines 95 --statements 95 --functions 93 --branches 86 --exclude \"test/**\" --exclude \"vendor/**\" --exclude \"src/ui/calendar.js\" --exclude \"src/ui/navigation.js\" --exclude \"src/ui/sections-sortable.js\" --exclude \"src/ui/tasks/task-calendar-actions.js\" --exclude \"src/ui/tasks/task-form-ui.js\" --exclude \"src/ui/tasks/task-subsection-zone.js\" --exclude \"src/ui/tasks/tasks-actions.js\" --exclude \"src/ui/tasks/tasks-render.js\" --exclude \"src/ui/tasks/tasks-sortable.js\" --exclude \"src/ui/tasks/tasks-render-helpers.js\" --exclude \"src/ui/tasks/task-reminders.js\" --exclude \"src/ui/tasks/task-virtualization.js\" --exclude \"src/ui/time-maps.js\" --exclude \"src/ui/calendar-event-modal.js\" --exclude \"src/ui/report.js\" --exclude \"src/ui/tasks/tasks.js\" --reporter=text --reporter=lcov mocha \"test/**/*.test.js\" --reporter=min --exit",
    "coverage": "nyc mocha \"test/**/*.test.js\""
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^3.1.7",
    "husky": "^8.0.3",
    "mocha": "^10.3.0",
    "nyc": "^15.1.0",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "chrono-node": "^2.9.0"
  }
}
